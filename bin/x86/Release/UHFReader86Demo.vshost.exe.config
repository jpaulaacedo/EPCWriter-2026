<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <configSections>
        <sectionGroup name="userSettings" type="System.Configuration.UserSettingsGroup, System, Version=2.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" >
            <section name="UHFReader86Demo.Properties.Settings" type="System.Configuration.ClientSettingsSection, System, Version=2.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" allowExeDefinition="MachineToLocalUser" requirePermission="false" />
        </sectionGroup>
    </configSections>
    <connectionStrings>
        <add name="UHFReader86Demo.Properties.Settings.ConnectionString"
            connectionString="server=localhost; port=3306; user id=root; password=admin123; database=assetmanagement; SslMode=none" />
    </connectionStrings>
    <userSettings>
        <UHFReader86Demo.Properties.Settings>
            <setting name="AssetManagemetUrl" serializeAs="String">
                <value>http:\\assetmanagement.com</value>
            </setting>
        </UHFReader86Demo.Properties.Settings>
    </userSettings>
</configuration>